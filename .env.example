# Скопіюйте цей файл як .env і вставте свій ключ:
#   cp .env.example .env

# Обов'язково: ключ API OpenAI
OPENAI_API_KEY=sk-your-api-key-here

# Модель для відповідей у чаті
OPENAI_MODEL=gpt-4o-mini

# Модель для ембедінгів (потрібна лише для програми 3_rag.py)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Параметри запиту до Chat Completions API
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1000
OPENAI_TOP_P=1.0
OPENAI_FREQUENCY_PENALTY=0.0
OPENAI_PRESENCE_PENALTY=0.0

# Папка з текстовими файлами для RAG (якщо використовуєте свою папку)
RAG_DATA_DIR=data

# Готові PDF-каталоги (генеруються скриптом generate_catalogs.py):
#   data/catalogs/dask_catalog.pdf
#   data/catalogs/goodwine_catalog.pdf

# Скільки фрагментів документів підставляти в контекст (програма 3_rag.py)
RAG_TOP_K=3

# Розмір фрагмента тексту (більше = менше фрагментів = швидша індексація)
RAG_CHUNK_SIZE=2000
